# 1. Ollama Cloud Endpoint (Required for Agent Swarm)
# You can use a local Ollama instance (http://localhost:11434) or a cloud provider
OLLAMA_BASE_URL=https://cloud.ollama.com

# 2. Firecrawl API Key (Required for OSINT WebCrawler Agent)
# Get a free API key at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here
